# ============================================================
#  GSRP Backend — Environment Variables
#  ⚠ NEVER commit this file to Git (.gitignore must include .env)
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/gsrp_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=1234

# ── JWT ──────────────────────────────────────────────────────
# Generate a strong secret for production:
#   openssl rand -base64 64
JWT_SECRET=change-this-to-a-strong-random-secret-before-deploying
JWT_EXPIRATION_MS=86400000

# ── File Upload ───────────────────────────────────────────────
# Directory where uploaded supporting documents are stored on disk.
# Can be an absolute path (recommended in production) or a relative path.
# Default (if not set): ./uploads/documents  (relative to working directory)
FILE_UPLOAD_DIR=./uploads/documents
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=15MB

# ── Spring Profile ────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
